{
  "name": "resume",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "Local-first Mac utility for finding and resuming AI coding sessions.",
  "type": "module",
  "main": "dist/src/main/main.js",
  "scripts": {
    "dev": "pnpm run build:main && concurrently -k \"vite --host 127.0.0.1\" \"wait-on tcp:5173 && RESUME_DEV=1 electron .\"",
    "build:main": "tsc -p tsconfig.main.json && cp src/main/preload.cjs dist/src/main/preload.cjs",
    "build": "pnpm run build:main && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit",
    "start": "electron .",
    "package": "pnpm run build && electron-builder --mac --config.directories.output=release"
  },
  "build": {
    "appId": "dev.cbarrell.resume",
    "productName": "Resume",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      "app-icon.png"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ]
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "minisearch": "^7.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/ui": "^2.1.0",
    "concurrently": "^9.1.0",
    "electron": "^36.0.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.0",
    "wait-on": "^8.0.0"
  }
}
